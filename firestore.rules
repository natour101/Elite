rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email == "admin@Elite.jo";
    }

    function isMediatorProductStatusUpdate() {
      return resource != null
        && request.resource.data.keys().hasAll(resource.data.keys())
        && request.resource.data.name == resource.data.name
        && request.resource.data.productNumber == resource.data.productNumber
        && request.resource.data.category == resource.data.category
        && request.resource.data.brand == resource.data.brand
        && request.resource.data.description == resource.data.description
        && request.resource.data.price == resource.data.price
        && request.resource.data.imageUrl == resource.data.imageUrl
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.isFeatured == resource.data.isFeatured
        && request.resource.data.stock == resource.data.stock;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isMediatorProductStatusUpdate();
    }

    match /mediators/{mediatorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mediator_codes/{code} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /publication_requests/{requestId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
