rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Temporary open rules so the current Flutter portal can manage products,
    // mediators, and metrics without Firebase Auth. Tighten these later when
    // moving to production authentication.

    match /products/{productId} {
      allow read, write: if true;
    }

    match /mediators/{mediatorId} {
      allow read, write: if true;
    }

    match /mediator_codes/{code} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }

    match /publication_requests/{requestId} {
      allow read, write: if true;
    }

    match /public_metrics/{metricId} {
      allow read, write: if true;
    }
  }
}
